# Project Nexus — Environment Variables Template
# ================================================
# Copy this file to .env for local development — NEVER commit .env
# Production: store all values in Azure Key Vault + GitHub Secrets
# Reference: CLAUDE.md §2 (Secrets constraint)

# ── Snowflake ──────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=          # never hardcode — MEMORY C-003
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# ── Azure ML ───────────────────────────────────────────
AZURE_ML_WORKSPACE=
AZURE_ML_SUBSCRIPTION_ID=
AZURE_ML_RESOURCE_GROUP=
AZURE_KEY_VAULT_NAME=         # e.g. nexus-kv

# ── LLM API Keys ───────────────────────────────────────
# Perplexity: perplexity.ai/settings/api
# Note: Perplexity Pro includes $5/mo credit; usage above that is billed separately
PERPLEXITY_API_KEY=           # pplx-...

# Gemini: aistudio.google.com → Get API Key
# Note: Gemini AI Pro subscription ≠ API access; AI Studio key is separate
GEMINI_API_KEY=               # AIza...

# OpenAI: platform.openai.com → API Keys
# Note: ChatGPT Team subscription ≠ API access; platform.openai.com billing is separate
OPENAI_API_KEY=               # sk-...
