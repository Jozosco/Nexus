# Project Nexus — Environment Variables Template
# ================================================
# Copy this file to .env for local development — NEVER commit .env
# Production: store all values in Azure Key Vault + GitHub Secrets
# Reference: CLAUDE.md §2 (Secrets constraint)

# ── Snowflake ──────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=          # never hardcode — MEMORY C-003
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# ── Azure ML ───────────────────────────────────────────────
AZURE_ML_WORKSPACE=
AZURE_ML_SUBSCRIPTION_ID=
AZURE_ML_RESOURCE_GROUP=
AZURE_KEY_VAULT_NAME=         # e.g. nexus-kv

# ── Data Source API Keys ───────────────────────────────────
# FRED: fred.stlouisfed.org → My Account → API Keys (무료)
FRED_API_KEY=                 # Fed 금리, CPI, 거시경제 시계열 (WBS 1.1.2)

# EIA: eia.gov/opendata → Register → Generate key (무료)
EIA_API_KEY=                  # WTI/Brent 유가 일간 시계열 (WBS 1.1.2)

# BOK ECOS: ecos.bok.or.kr → 회원가입 → Open API 신청 (무료)
BOK_ECOS_API_KEY=             # KRW/USD 환율 (T+2 결제 — MEMORY M-002) (WBS 1.1.2)

# ── LLM API Keys ───────────────────────────────────────────
# Perplexity: perplexity.ai/settings/api
# Note: Perplexity Pro includes $5/mo credit; usage above that is billed separately
# MEMORY L-006/L-007: 모델명은 perplexity_client.py 상수로 관리 — 하드코딩 금지
PERPLEXITY_API_KEY=           # pplx-...

# Gemini: aistudio.google.com → Get API Key
# Note: Gemini AI Pro subscription ≠ API access; AI Studio key is separate (MEMORY L-005)
GEMINI_API_KEY=               # AIza...

# OpenAI: platform.openai.com → API Keys
# Note: ChatGPT Team subscription ≠ API access; platform.openai.com billing is separate (MEMORY L-004)
OPENAI_API_KEY=               # sk-...
